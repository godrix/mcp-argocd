# Argo CD MCP Server — copy to .env and adjust

# =============================================================================
# Profile mode (pick ONE — mutually exclusive)
# =============================================================================

# --- A) Single instance (implicit profile "default") ---
# ARGOCD_URL=https://argocd.example.io
# ARGOCD_API_KEY=your-bearer-token-here

# --- B) Multiple environments (do NOT set ARGOCD_URL) ---
# ARGOCD_DEFAULT_PROFILE=qa
# ARGOCD_PROFILES=qa,stg,prod
# ARGOCD_URL_PROFILES=https://argocd-qa.example.io,https://argocd-stg.example.io,https://argocd-prod.example.io

# =============================================================================
# Authentication (API key OR argocd_login via CLI — one method per profile)
# =============================================================================

# Default / single-instance token
# ARGOCD_API_KEY=your-bearer-token-here

# Per-profile tokens (multi-env)
# ARGOCD_API_KEY_QA=
# ARGOCD_API_KEY_STG=
# ARGOCD_API_KEY_PROD=

# Positional keys (same order as ARGOCD_PROFILES)
# ARGOCD_API_KEYS=token-qa,token-stg,token-prod

# Aliases also accepted: ARGOCD_TOKEN, ARGOCD_TOKEN_<PROFILE>

# =============================================================================
# Safety & behaviour
# =============================================================================

# Block sync and other mutations (default: true)
ARGOCD_READ_ONLY=true

# Allow refresh-application tool (default: true)
ARGOCD_ALLOW_REFRESH=true

# =============================================================================
# Application cache (substring search via search-applications)
# =============================================================================

# ARGOCD_APP_CACHE_ENABLED=true
# ARGOCD_APP_CACHE_TTL_SECONDS=300

# =============================================================================
# Optional: MCP priority / bookmark apps
# (Argo CD UI favorites are browser-only — not readable via API)
# =============================================================================

# ARGOCD_PRIORITY_APPS=frontend,api-gateway
# ARGOCD_PRIORITY_APPS_QA=my-service,worker-jobs
# ARGOCD_PRIORITY_APPS_PROD=checkout-api

# =============================================================================
# CLI login (SSO / username-password)
# =============================================================================

# Path to argocd CLI config (default: ~/.config/argocd/config)
# ARGOCD_CONFIG=

# Pass --grpc-web to argocd login (default: true)
# ARGOCD_GRPC_WEB=true

# Skip TLS verification (default: false)
# ARGOCD_INSECURE=false

# Per-profile overrides: ARGOCD_PROFILE_<NAME>_CONTEXT, _LABEL, _URL
# Legacy JSON file: ARGOCD_PROFILES_FILE=./argocd.profiles.json
